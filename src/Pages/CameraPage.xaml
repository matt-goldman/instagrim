<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:icons="clr-namespace:Plugin.Maui.Lucide.Controls;assembly=Plugin.Maui.Lucide"
             NavigationPage.HasNavigationBar="False"
             x:Class="instagrim.Pages.CameraPage">
    <Grid VerticalOptions="Fill"
          HorizontalOptions="Fill">
        <mct:CameraView HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        IsEnabled="False"
                        x:Name="Camera"/>
        
        <ImageButton Source="{FontImageSource FontFamily=Lucide,
                                              Glyph={StaticResource CircleChevronDown},
                                              Color={StaticResource Primary}}"
                     WidthRequest="40"
                     HeightRequest="40"
                     VerticalOptions="Start"
                     HorizontalOptions="End"
                     Margin="30"
                     BackgroundColor="Transparent"
                     x:Name="CloseButton"
                     Clicked="CloseButton_OnClicked" />
    </Grid>
</ContentPage>